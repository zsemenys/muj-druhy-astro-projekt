---
// Získáme aktuální cestu pro inteligentní přepínač jazyků
const currentPath = Astro.url.pathname;
// Jednoduchá logika pro záměnu jazykového prefixu
const czPath = currentPath.replace(/^\/en/, '/cz') || '/cz';
const enPath = currentPath.replace(/^\/cz/, '/en') || '/en/welcome';

const navLinks = [
  {
    label: "Produkty a služby",
    href: "/cz/produkty-a-sluzby",
    dropdown: [
      { href: "/cz/produkty-a-sluzby/monitoring-solarnich-elektraren", label: "Monitoring FVE" },
      { href: "/cz/produkty-a-sluzby/dispecink", label: "Dispečink" },
      { href: "/cz/produkty-a-sluzby/servis-full", label: "Servis FVE" },
      { href: "/cz/produkty-a-sluzby/opravy-menicu", label: "Opravy měničů" },
      { href: "/cz/produkty-a-sluzby/bateriova-uloziste", label: "Bateriová úložiště" },
    ]
  },
  { href: "/cz/eshop", label: "E-shop" },
  { href: "/cz/o-spolecnosti", label: "O společnosti" },
];
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">

      <!-- LOGO -->
      <a href="/" class="text-2xl font-bold tracking-tight text-primary-600 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-accent-400" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
        </svg>
        SOLARMON
      </a>

      <!-- DESKTOP NAV -->
      <nav class="hidden lg:flex gap-6 items-center">
        {navLinks.map(link => (
          link.dropdown ? (
            <div class="relative group">
              <a href={link.href} class="text-gray-600 font-medium hover:text-primary-600 transition flex items-center gap-1 py-4">
                {link.label}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <!-- DROPDOWN MENU -->
              <div class="absolute top-full left-0 w-64 bg-white border border-gray-100 shadow-xl rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0 overflow-hidden flex flex-col z-50">
                {link.dropdown.map(dropLink => (
                  <a href={dropLink.href} class="px-5 py-3 text-gray-600 font-medium hover:bg-primary-50 hover:text-primary-700 transition-colors border-b border-gray-50 last:border-0">
                    {dropLink.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a href={link.href} class="text-gray-600 font-medium hover:text-primary-600 transition py-4">
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- RIGHT SIDE: Lang + CTA -->
      <div class="hidden lg:flex items-center gap-6">
        <!-- LANG SWITCHER -->
        <div class="flex items-center gap-2 text-sm font-semibold">
          <a href={czPath} class={`transition ${currentPath.includes('/cz') ? 'text-primary-600 font-bold' : 'text-gray-400 hover:text-primary-600'}`}>CZ</a>
          <span class="text-gray-300">|</span>
          <a href={enPath} class={`transition ${currentPath.includes('/en') ? 'text-primary-600 font-bold' : 'text-gray-400 hover:text-primary-600'}`}>EN</a>
        </div>

        <a href="/cz/kontakty" class="bg-primary-600 text-white px-5 py-2.5 rounded-xl font-medium hover:bg-primary-700 shadow-lg shadow-primary-500/30 transition hover:-translate-y-0.5">
          Nezávazná poptávka
        </a>
      </div>

      <!-- MOBILE MENU BUTTON -->
      <button id="menuBtn" class="lg:hidden text-gray-600 hover:text-primary-600 transition">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" stroke="currentColor">
          <path stroke-width="2" stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>

    </div>
  </div>

  <!-- MOBILE MENU -->
  <div id="mobileMenu" class="hidden lg:hidden border-t border-gray-100 bg-white max-h-[calc(100vh-4rem)] overflow-y-auto">
    <div class="px-4 py-6 flex flex-col gap-4">
      {navLinks.map(link => (
        <div class="flex flex-col gap-2">
          <a href={link.href} class="text-lg font-bold text-gray-900 hover:text-primary-600">
            {link.label}
          </a>
          {link.dropdown && (
            <div class="flex flex-col pl-4 border-l-2 border-primary-100 gap-2 mt-2">
              {link.dropdown.map(dropLink => (
                <a href={dropLink.href} class="text-gray-600 hover:text-primary-600 font-medium">
                  {dropLink.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <div class="flex gap-4 mt-4 pt-4 border-t border-gray-100">
        <a href={czPath} class={`font-bold ${currentPath.includes('/cz') ? 'text-primary-600' : 'text-gray-400'}`}>CZ</a>
        <a href={enPath} class={`font-bold ${currentPath.includes('/en') ? 'text-primary-600' : 'text-gray-400'}`}>EN</a>
      </div>
      <a href="/cz/kontakty" class="bg-primary-600 text-white text-center py-3 rounded-xl mt-4 font-medium shadow-md shadow-primary-500/20">
        Nezávazná poptávka
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("menuBtn");
  const menu = document.getElementById("mobileMenu");
  btn?.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>