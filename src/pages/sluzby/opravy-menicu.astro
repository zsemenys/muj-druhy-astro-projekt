---
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "../../components/CTA.astro";
---

<MainLayout 
  title="Opravy střídačů fotovoltaiky | Diagnostika měničů"
  description="Opravy a diagnostika střídačů fotovoltaických elektráren všech výrobců."
>

<section class="bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-bold">
      Opravy střídačů fotovoltaických elektráren
    </h1>
    <p class="mt-6 text-lg text-gray-600">
      Porucha měniče znamená okamžitý výpadek výroby. Zajistíme rychlou diagnostiku a opravu.
    </p>
  </div>
</section>

<section class="py-16">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-3xl font-bold mb-6">Co opravujeme</h2>
    <div class="grid md:grid-cols-2 gap-6 text-lg">
      <div>✔ Stringové střídače</div>
      <div>✔ Centrální měniče</div>
      <div>✔ Diagnostika poruch</div>
      <div>✔ Návrh řešení</div>
    </div>
  </div>
</section>

<CTA />

</MainLayout>