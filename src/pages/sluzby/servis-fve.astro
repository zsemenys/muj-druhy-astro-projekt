---
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "../../components/CTA.astro";
---

<MainLayout 
  title="Servis fotovoltaických elektráren | SOLARMON"
  description="Pravidelný i havarijní servis FVE po celé ČR. Diagnostika, opravy a optimalizace výkonu elektráren."
>

<section class="bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-bold">
      Servis fotovoltaických elektráren
    </h1>
    <p class="mt-6 text-lg text-gray-600">
      Každá porucha FVE znamená ztrátu výroby. Zajistíme pravidelný i havarijní servis.
    </p>
  </div>
</section>

<section class="py-16">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-3xl font-bold mb-6">Co servis zahrnuje</h2>
    <div class="grid md:grid-cols-2 gap-6 text-lg">
      <div>✔ Diagnostika poruch</div>
      <div>✔ Revize a kontroly</div>
      <div>✔ Termovizní měření</div>
      <div>✔ Optimalizace výkonu</div>
    </div>
  </div>
</section>

<section class="py-16 bg-gray-50">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-3xl font-bold mb-6">Proč pravidelný servis</h2>
    <p class="text-lg text-gray-600">
      Neudržovaná FVE může ztratit až desítky procent výkonu bez viditelných příznaků.
    </p>
  </div>
</section>

<CTA />

</MainLayout>