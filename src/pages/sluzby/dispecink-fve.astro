---
import MainLayout from "../../layouts/MainLayout.astro";
import CTA from "../../components/CTA.astro";
---

<MainLayout 
  title="Dispečink fotovoltaických elektráren | 24/7 dohled"
  description="Dispečink FVE 24/7. Okamžitá reakce na alarmy a výpadky elektráren."
>

<section class="bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 py-16 md:py-24">
    <h1 class="text-4xl md:text-5xl font-bold">
      Dispečink fotovoltaických elektráren 24/7
    </h1>
    <p class="mt-6 text-lg text-gray-600">
      Neustálý dohled nad provozem elektráren a okamžitá reakce na výpadky.
    </p>
  </div>
</section>

<section class="py-16">
  <div class="max-w-5xl mx-auto px-4">
    <h2 class="text-3xl font-bold mb-6">Co zajišťuje dispečink</h2>
    <div class="grid md:grid-cols-2 gap-6 text-lg">
      <div>✔ 24/7 monitoring alarmů</div>
      <div>✔ Okamžitá reakce</div>
      <div>✔ Komunikace s distributory</div>
      <div>✔ Koordinace servisních zásahů</div>
    </div>
  </div>
</section>

<CTA />

</MainLayout>