---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<MainLayout 
  title="Blog o fotovoltaice | SOLARMON"
  description="Odborné články o monitoringu, servisu a provozu FVE."
>

<section class="max-w-5xl mx-auto px-4 py-16">
  <h1 class="text-4xl font-bold mb-10">Blog</h1>

  <div class="grid gap-6">
    {posts.map(post => (
           <a href={`/blog/${post.id}`} class="p-6 border rounded-2xl hover:shadow-lg transition">
        <h2 class="text-2xl font-semibold">{post.data.title}</h2>
        <p class="text-gray-600 mt-2">{post.data.description}</p>
      </a>
    ))}
  </div>

</section>

</MainLayout>
